{
    "compilerOptions": {
        "module": "commonjs",
        "noImplicitAny": true,
        "outDir": "lib",
        "preserveConstEnums": true,
        "removeComments": true,
        "sourceMap": true,
        "target": "es2017",
        "skipLibCheck": true,
        "lib": [
            "es2017",
            "esnext.asynciterable",
            "dom"
        ]
    },
    "compileOnSave": true,
    "include": [
        "src"
    ]
}