rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow access to field users. 
    // Since we are using local-first auth for offline field work, 
    // we allow writes to these collections.
    match /fichas/{id} { allow read, write: if true; }
    match /tuberias/{id} { allow read, write: if true; }
    match /fotos/{id} { allow read, write: if true; }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
