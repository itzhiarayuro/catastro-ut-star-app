rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Security Hardening: Permitir acceso SÓLO si el usuario está autenticado por Firebase Auth real
    // La persistencia offline seguirá funcionando con estas reglas activas ya que el caché local
    // es autorizado por el token de sesión emitido una vez hayamos hecho login.
    // Permisos con Auditoría
    match /fichas/{id} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && 
                       request.resource.data.createdBy == request.auth.uid &&
                       request.resource.data.creatorEmail is string;
    }
    
    match /historial_fichas/{id} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && 
                       request.resource.data.createdBy == request.auth.uid;
    }
    
    match /marcaciones/{id} { allow read, write: if request.auth != null; }
    match /tuberias/{id} { allow read, write: if request.auth != null; }
    match /fotos/{id} { allow read, write: if request.auth != null; }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
