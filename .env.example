# Guía de variables de entorno requeridas por la aplicación
# Renombra este archivo a .env.local y llenar con credenciales reales

# Firebase Configuration
VITE_FIREBASE_API_KEY="INSERTAR_AQUI"
VITE_FIREBASE_AUTH_DOMAIN="INSERTAR_AQUI"
VITE_FIREBASE_PROJECT_ID="INSERTAR_AQUI"
VITE_FIREBASE_STORAGE_BUCKET="INSERTAR_AQUI"
VITE_FIREBASE_MESSAGING_SENDER_ID="INSERTAR_AQUI"
VITE_FIREBASE_APP_ID="INSERTAR_AQUI"

# Google Apps Script (Drive Sync)
VITE_GAS_DRIVE_SYNC_URL="https://script.google.com/macros/s/TU_SCRIPT_ID/exec"
VITE_GAS_SECRET_TOKEN="INSERTAR_TOKEN_SECRETO_AQUI"

# Google Maps (Opcional - para estilos personalizados)
VITE_GOOGLE_MAPS_ID="INSERTAR_MAP_ID_AQUI"
